; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="water_world"
run/main_scene="uid://belnvvxoj5goq"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/image="uid://cg7g5pl0c48ud"
config/icon="uid://cg7g5pl0c48ud"

[autoload]

wave_settings="*uid://jijhlk2ru0nf"
racetrack="*uid://dxjrkkt5376pt"

[debug]

settings/stdout/print_fps=true
settings/gdscript/always_track_local_variables=true
gdscript/warnings/untyped_declaration=1

[debug_draw_3d]

settings/addon_root_folder="res://addons/debug_draw_3d"

[display]

window/size/viewport_width=1800
window/size/viewport_height=900
window/size/initial_position_type=0
window/vsync/vsync_mode=0

[editor_plugins]

enabled=PackedStringArray("res://addons/radial_progress/plugin.cfg")

